# Backend environment variables (local development)
# Copy to apps/backend/.env (never commit .env to git!)

# PostgreSQL – local
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASS=postgres
DB_NAME=candidate_platform

# PostgreSQL – production (Render provides DATABASE_URL automatically)
# DATABASE_URL=postgres://user:password@host:port/dbname

# Port
PORT=3333

# Frontend origin for CORS
FRONTEND_URL=http://localhost:4200

# Set to "production" to disable synchronize in TypeORM
NODE_ENV=development
